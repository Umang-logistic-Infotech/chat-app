# ============================================
# Server Configuration
# ============================================
PORT=5000

# ============================================
# Database Configuration
# ============================================
DATABASE_HOST=your_database_host
DATABASE_USERNAME=your_database_username
DATABASE_PASS=your_database_password
DATABASE_NAME=your_database_name
DB_PASSWORD_SALTROUNDS=your_salt_rounds

# ============================================
# Frontend URLs
# ============================================
# Local development
FRONT_END_URL=http://localhost:3000

# Network access (for testing on other devices)
FRONT_END_URL_NETWORK=http://192.168.0.131:3000

# ============================================
# Image Upload Base URL
# ============================================
# Local development
IMAGE_UPLOAD_URL=http://localhost:5000

# Network access (uncomment if needed)
# IMAGE_UPLOAD_URL=http://192.168.0.131:5000

# ============================================
# Authentication
# ============================================
JWT_SECRET=your_jwt_secret_here
